---
import PageHero from "@/components/PageHero.jsx";
import Layout from "@/layouts/Layout.astro";
import "@/styles/2025/global.css";

import { ticketsData } from "@/lib/graphql/queries/tickets.query.ts";
import Faq from "@components/Faq.astro";
const ticketsResponse = ticketsData?.tickets?.[0]?.tickets || [];
---

<Layout title="Tickets — Open Source Day 2026" activePath="/tickets">
  <!-- Hero -->
  <PageHero
    client:load
    badge="REGISTRATION STARTED"
    title="OSD 2026"
    titleGradient="TICKETS"
    subtitle="Secure your spot at India's biggest open source conference. Ticket sales are live now!"
    primaryCta={{ text: "Buy Now", href: "/purchase", external: false }}
  />

  <!-- Ticket Tiers -->
  <section class="py-20 px-4 bg-white" id="ticket-tiers">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Buy <span class="gradient-text">Tickets Now</span></h2>
        <p class="text-gray-500">Choose the ticket that fits you best</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          ticketsResponse.map((ticket: any) => (
            <div
              class={`relative border-2 rounded-2xl p-6 text-center hover:shadow-lg transition-all hover:-translate-y-1 bg-white ${ticket.popular ? "border-green-300 scale-105" : "border-gray-200"}`}
            >
              {ticket.alert && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                  <span class={`text-xs font-bold px-3 py-1 rounded-full ${ticket.alert.classes}`}>{ticket.alert.text}</span>
                </div>
              )}
              <h3 class="font-black text-xl text-gray-900 mb-2 mt-2">{ticket.name}</h3>
              <div class="flex items-center justify-center gap-2 mb-1">
                <div class="text-3xl font-black gradient-text">₹{ticket.price}</div>
                {ticket.originalPrice && Number(ticket.price) < Number(ticket.originalPrice) && (
                  <span class="text-lg text-gray-400 line-through font-semibold">₹{ticket.originalPrice}</span>
                )}
              </div>
              {ticket.originalPrice && Number(ticket.price) < Number(ticket.originalPrice) && (
                <p class="text-green-600 text-xs font-semibold mb-1">
                  Save {ticket.discountedPrice} on this ticket!
                </p>
              )}
              {ticket.couponCode && (
                <div class="inline-flex items-center gap-1.5 bg-green-50 border border-green-200 rounded-lg px-3 py-1.5 mb-3 mt-2">
                  <svg class="w-3.5 h-3.5 text-green-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 14.25l6-6m4.5-3.493V21.75l-3.75-1.5-3.75 1.5-3.75-1.5-3.75 1.5V4.757c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0 1 11.186 0c1.1.128 1.907 1.077 1.907 2.185Z" />
                  </svg>
                  <span class="text-xs text-gray-500">Use code:</span>
                  <code class="text-xs font-bold text-green-700 tracking-wide">{ticket.couponCode.trim()}</code>
                  <button
                    type="button"
                    data-coupon={ticket.couponCode.trim()}
                    onclick="(function(btn){var code=btn.getAttribute('data-coupon');navigator.clipboard.writeText(code).then(function(){var icon=btn.querySelector('.copy-icon');var check=btn.querySelector('.check-icon');icon.classList.add('hidden');check.classList.remove('hidden');setTimeout(function(){icon.classList.remove('hidden');check.classList.add('hidden');},1500);});})(this)"
                    class="ml-1 text-gray-400 hover:text-green-600 transition-colors"
                    title="Copy code"
                  >
                    <svg class="copy-icon w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" />
                    </svg>
                    <svg class="check-icon w-3.5 h-3.5 hidden text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  </button>
                </div>
              )}
              <p class="text-gray-500 text-sm mb-5">{ticket.description}</p>
              {ticket.name === "Regular Ticket" && (
                <div class="bg-green-50 border border-green-200 rounded-lg px-3 py-2 mb-4 text-left">
                  <span class="text-sm font-medium text-green-800">
                    This is another chance for you to avail the benefit use code <span class="font-bold">"OSDLOVE"</span> to get Flat discount 20% OFF on this Ticket
                  </span>
                </div>
              )}
              {ticket?.featureTitle && <p class="text-gray-900 font-semibold text-sm mb-2 text-left">{ticket?.featureTitle}</p>}
              <ul class="text-left space-y-2 text-sm text-gray-600 mb-6">
                {ticket?.features?.map((f: any) => (
                  <li class="flex items-start gap-2">
                    <svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                    {f?.featureText ?? "-"}
                  </li>
                ))}
              </ul>
              {ticket.available ? (
                <a
                  href={ticket.konfhubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`block w-full py-3 rounded-full font-bold text-sm transition-all ${ticket.popular ? "bg-gray-900 hover:bg-gray-800 text-white" : "border-2 border-gray-200 hover:border-gray-900 text-gray-700"}`}
                >
                  {ticket.linkText || "Coming Soon"}
                </a>
              ) : (
                <button
                  class={`block w-full py-3 rounded-full font-bold text-sm transition-all ${ticket.popular ? "bg-gray-900 hover:bg-gray-800 text-white" : "border-2 border-gray-200 hover:border-gray-900 text-gray-700"}`}
                >
                  {ticket.linkText || "Coming Soon"}
                </button>
              )}
              {ticket?.extra ? <p class="text-gray-500 text-sm my-5 text-left">{ticket.extra}</p> : null}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">What's <span class="gradient-text">Included</span></h2>
        <p class="text-gray-500">Everything you get with your OSD 2026 ticket</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          [
            { label: "Full Conference Access", desc: "Access all keynotes, talks, panels, and networking sessions throughout the day." },
            { label: "Lunch & Refreshments", desc: "Enjoy complimentary lunch and refreshments throughout the event." },
            { label: "OSD Goodies", desc: "Take home exclusive OSD merchandise and community goodies." },
          ].map(({ label, desc }) => (
            <div class="border border-gray-100 bg-white hover:border-green-200 hover:shadow-md p-7 rounded-2xl transition-all duration-300">
              <div class="w-8 h-8 mb-4 rounded-lg bg-green-50 border border-green-100 flex items-center justify-center">
                <svg class="w-4 h-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
              </div>
              <h3 class="font-bold text-gray-900 mb-2">{label}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <Faq />
  <!-- Bottom CTA -->
  <section class="py-16 px-4 bg-gray-50 text-center">
    <h3 class="text-xl font-bold text-gray-900 mb-2">Questions about <span class="gradient-text">tickets?</span></h3>
    <a href="mailto:opensourceweekend@gmail.com" class="text-green-600 hover:underline font-semibold">opensourceweekend@gmail.com</a>
  </section>
</Layout>
