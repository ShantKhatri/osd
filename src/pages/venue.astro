---
import LocationIcon from "@/assets/icons/location.svg";
import PageHero from "@/components/PageHero.jsx";
import { SITE, VENUE } from "@/config/config.ts";
import Layout from "@/layouts/Layout.astro";
import "@/styles/2025/global.css";
---

<Layout title="Venue — Open Source Day 2026" activePath="/venue">
  <!-- Hero -->
  <PageHero
    client:load
    badge="VENUE CONFIRMED"
    title="OSD 2026"
    titleGradient="VENUE"
    subtitle="Finally we have an amazing venue for Open Source Day. We are bringing #OSD26 to a legendary campus in Gandhinagar. Lush greenery, massive spaces, and pure open-source energy. 🌿💻"
    primaryCta={{ text: "View Schedule", href: "/schedule" }}
    secondaryCta={{ text: "View 2025 Venue", href: "/2025/venue" }}
  />

  <!-- Venue Details -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10">
      <div class="rounded-3xl border border-gray-100 p-8 bg-white shadow-sm">
        <h2 class="text-4xl font-black text-green-600 mb-8">Venue Details</h2>

        <div class="mb-6">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-green-600 mt-1 text-white flex items-center justify-center">
              <LocationIcon class="w-5 h-5" />
            </div>
            <div>
              <h3 class="text-lg font-bold">Location</h3>
              <p class="text-gray-700 font-semibold ">
                <a href={VENUE.googleMapsLink} target="_blank" rel="noreferrer noopener" class="text-green-600 hover:text-green-700 hover:no-underline transition">
                  {VENUE.name}
                </a>
              </p>
              <p class="text-gray-500 text-sm">{VENUE.address}</p>
            </div>
          </div>
        </div>

        <div class="mb-6">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-green-600 mt-1 text-white flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 9h10m-7 4h4m-5 5h6a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold">Date & Time</h3>
              <p class="text-gray-700 font-semibold">{VENUE.date} · 9:00 AM - 6:00 PM</p>
              <p class="text-gray-500 text-sm">{VENUE.format}</p>
            </div>
          </div>
        </div>

        <div>
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-green-600 mt-1 text-white flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M5 14h14M7 18h10"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold">Accessibility</h3>
              <ul class="list-disc text-gray-500 text-sm ml-5">
                <li>Wheelchair accessible venue</li>
                <li>Public transport connectivity</li>
                <li>Parking facilities available</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-3xl border border-gray-100 p-8 bg-white shadow-sm">
        <h2 class="text-4xl font-black text-green-600 mb-8">Venue Features</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-gray-700">
          <div class="flex items-center gap-3">
            <span class="w-7 h-7 shrink-0 rounded-full bg-green-600 text-white flex items-center justify-center">A</span> Main Auditorium (600 seats)
          </div>
          <div class="flex items-center gap-3">
            <span class="w-7 h-7 shrink-0 rounded-full bg-green-600 text-white flex items-center justify-center">A</span> Amphitheatre
          </div>
          <div class="flex items-center gap-3">
            <span class="w-7 h-7 shrink-0 rounded-full bg-green-600 text-white flex items-center justify-center">L</span> Lawns and Open Event Grounds
          </div>
          <div class="flex items-center gap-3">
            <span class="w-7 h-7 shrink-0 rounded-full bg-green-600 text-white flex items-center justify-center">S</span> Seminar and Workshop Rooms
          </div>
          <div class="flex items-center gap-3">
            <span class="w-7 h-7 shrink-0 rounded-full bg-green-600 text-white flex items-center justify-center">H</span> High-Speed Campus WiFi
          </div>
          <div class="flex items-center gap-3">
            <span class="w-7 h-7 shrink-0 rounded-full bg-green-600 text-white flex items-center justify-center">L</span> Library & Learning Resources
          </div>
          <div class="flex items-center gap-3">
            <span class="w-7 h-7 shrink-0 rounded-full bg-green-600 text-white flex items-center justify-center">C</span> Cafeteria & Food Court
          </div>
          <div class="flex items-center gap-3">
            <span class="w-7 h-7 shrink-0 rounded-full bg-green-600 text-white flex items-center justify-center">P</span> Parking & Accessible Facilities
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-6xl mx-auto mt-10">
      <div class="rounded-2xl border border-gray-100 overflow-hidden h-[420px]">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3667.4973993967537!2d72.62634057516976!3d23.188536979057695!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x395c2a3c9618d2c5%3A0xc54de484f986b1fa!2sDhirubhai%20Ambani%20University!5e0!3m2!1sen!2sin!4v1773815481392!5m2!1sen!2sin" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
      <div class="text-right mt-3">
        <a
          href={VENUE.googleMapsLink}
          target="_blank"
          rel="noreferrer noopener"
          class="inline-flex items-center gap-2 text-sm font-semibold text-green-700 hover:text-green-900"
        >
          Open in Google Maps
        </a>
      </div>
    </div>
  </section>

  <!-- Getting There -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Getting <span class="gradient-text">There</span></h2>
        <p class="text-gray-500">{SITE.city} is well connected by air, rail, and road</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          [
            {
              label: "By Air",
              desc: `Sardar Vallabhbhai Patel International Airport (AMD) serves ${SITE.city}.`,
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />`,
            },
            {
              label: "By Train",
              desc: `${SITE.city} Junction is well-connected to major cities across India.`,
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />`,
            },
            {
              label: "By Road",
              desc: `Excellent connectivity from across ${SITE.city} and neighboring states. Ample parking.`,
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V6.375a1.125 1.125 0 0 1 1.125-1.125h9.75c.621 0 1.125.504 1.125 1.125v11.25m-12 0v1.5a1.5 1.5 0 0 0 3 0v-1.5m9 0v1.5a1.5 1.5 0 0 0 3 0v-1.5m0-11.25h2.625c.62１ 0 １.１２５．５０４ １．１２５ １．１２５V１５m－１８．７５ ０h１８．７５" />`,
            },
          ].map(({ label, desc, icon }) => (
            <div class="border border-gray-100 bg-white hover:border-green-200 hover:shadow-md p-7 rounded-2xl transition-all duration-300">
              <div class="w-10 h-10 mb-4 text-green-600">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" set:html={icon} />
              </div>
              <h3 class="font-bold text-gray-900 mb-2">{label}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 2025 Reference -->
  <section class="py-16 px-4 bg-white text-center">
    <h3 class="text-2xl font-black text-gray-900 mb-3">OSD 2025 was at <span class="gradient-text">Silver Oak University</span></h3>
    <p class="text-gray-500 mb-6 max-w-xl mx-auto">Check out the 2025 venue details and photos from the event.</p>
    <a
      href="/2025/venue"
      class="inline-flex items-center gap-2 font-bold text-white bg-gray-900 hover:bg-gray-800 px-8 py-3 rounded-full transition-all hover:scale-105"
    >
      View 2025 Venue
    </a>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 px-4 bg-gray-50 text-center">
    <h3 class="text-xl font-bold text-gray-900 mb-2">Want to be a <span class="gradient-text">venue partner?</span></h3>
    <p class="text-gray-500 mb-2">Reach out to us at</p>
    <a href="mailto:opensourceweekend@gmail.com" class="text-green-600 hover:underline font-semibold">opensourceweekend@gmail.com</a>
  </section>
</Layout>
