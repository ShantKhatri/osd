---
import Layout from "@/layouts/Layout.astro";
import Heading from "@components/Heading.astro";
import "@/styles/global.css";

import Location from "@/assets/icons/location.svg";
import CalendarClock from "@/assets/icons/calendarClock.svg";
import LayoutList from "@/assets/icons/layoutList.svg";

import { VENUE } from "@/config";
---

<Layout title="Venue — 2025 OSD">
  <!-- Heading Section -->
  <Heading title="The Venue" />

  <!-- Venue Details -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div
                class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0 mt-1"
              >
                <Location />
              </div>
              <div>
                <h3 class="text-xl font-semibold text-black mb-2">Location</h3>
                <p class="text-black">
                  Ahmedabad, Gujarat<br />
                  Exact Venue details will be shared<br />
                  with registered participants<br />
                  via email confirmation
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div
                class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0 mt-1"
              >
                <CalendarClock />
              </div>
              <div>
                <h3 class="text-xl font-semibold text-black mb-2">
                  Date & Time
                </h3>
                <p class="text-black">
                  October 05, 2025<br />
                  9:00 AM - 6:00 PM<br />
                  Full day event
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div
                class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0 mt-1"
              >
                <LayoutList />
              </div>
              <div>
                <h3 class="text-xl font-semibold text-black mb-2">
                  Accessibility
                </h3>
                <p class="text-black">
                  Wheelchair accessible venue<br />
                  Public transport connectivity<br />
                  Parking facilities available
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="light-card rounded-xl p-8">
          <h3 class="text-2xl font-bold text-black mb-6">Venue Features</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">Main Auditorium (600 seats)</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">5 Workshop Rooms</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">Exhibition Hall</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">Networking Lounge</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">High-Speed WiFi</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">Live Streaming Setup</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">Food Court</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">Accessibility Features</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <div class="my-10 justify-items-center">
    <iframe
      src="https://www.google.com/maps/d/embed?mid=10QGVjTs4XnCMNiFAl8VxStHAgt5BOiQ&hl=en&ehbc=2E312F"
      class="w-11/12 md:w-3/5 h-[480px] rounded-xl border-0 shadow-md"
      loading="lazy"
      allowfullscreen
    >
    </iframe>
  </div>
</Layout>
