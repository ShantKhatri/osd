---
import LocationIcon from "@/assets/icons/location.svg";
import PageHero from "@/components/PageHero.jsx";
import { SITE, VENUE } from "@/config/config.ts";
import Layout from "@/layouts/Layout.astro";
import "@/styles/2025/global.css";


const features = [
  { icon: "🏛️", label: "Main Auditorium", desc: "600 seats" },
  { icon: "🎭", label: "Amphitheatre", desc: "Open air stage" },
  { icon: "🌿", label: "Lawns & Grounds", desc: "Open event area" },
  { icon: "📚", label: "Seminar Rooms", desc: "Workshop spaces" },
  { icon: "📶", label: "Campus WiFi", desc: "High-speed internet" },
  { icon: "🍽️", label: "Cafeteria", desc: "Food & beverages" },
  { icon: "📖", label: "Library", desc: "Learning resources" },
  { icon: "🚗", label: "Parking", desc: "Ample facilities" },
];

const transport = [
  { emoji: "✈️", label: "Airport", sub: "Sardar Vallabhbhai Patel Intl (AMD)", dist: "~25 km" },
  { emoji: "🚉", label: "Railway Station", sub: "Gandhinagar Capital Station", dist: "~5 km" },
  { emoji: "🚌", label: "GSRTC Bus", sub: "Gandhinagar Bus Stand", dist: "~4 km" },
  { emoji: "🚇", label: "Metro (BRTS)", sub: "Infocity Circle", dist: "~2 km" },
  { emoji: "🚗", label: "By Road", sub: "Accessible via SH-17 & NH-147", dist: "Ample parking" },
  { emoji: "🛺", label: "Auto / Cab", sub: "Ola, Uber & local autos available", dist: "Available" },
];
---

<Layout title="Venue — Open Source Day 2026" activePath="/venue">
  <!-- Hero -->
  <PageHero
    client:load
    badge="VENUE CONFIRMED"
    title="OSD 2026"
    titleGradient="VENUE"
    subtitle="We are bringing #OSD26 to a legendary campus in Gandhinagar — DAIICT (Dhirubhai Ambani University). Lush greenery, massive spaces, and pure open-source energy. 🌿💻"
    primaryCta={{ text: "View Schedule", href: "/schedule" }}
    secondaryCta={{ text: "View 2025 Venue", href: "/2025/venue" }}
  />


  <!-- Photo Gallery -->
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-10">
        <span class="inline-block bg-green-100 text-green-700 text-xs font-bold px-3 py-1 rounded-full mb-3 tracking-widest uppercase">The Venue</span>
        <h2 class="text-3xl md:text-4xl font-black text-gray-900">
          A Glimpse of <span class="gradient-text">DAIICT</span>
        </h2>
      </div>

      <!-- Bento Grid -->
      <div class="flex flex-col md:flex-row gap-2 h-auto md:h-[480px]">

        <!-- Left: Hero image -->
        <div class="md:w-1/2 overflow-hidden rounded-2xl group relative">
          <img
            src="https://www.daiict.ac.in/sites/default/files/2021-04/Campus%2051.JPG"
            alt="DAIICT Campus"
            class="w-full h-64 md:h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl"></div>
        </div>

        <!-- Right: 2x2 grid -->
        <div class="md:w-1/2 grid grid-cols-2 gap-2">
          {[
            { src: "https://www.daiict.ac.in/sites/default/files/2021-04/Campus%2032.JPG", alt: "DAIICT Building" },
            { src: "https://www.daiict.ac.in/sites/default/files/2021-04/Campus%2004.JPG", alt: "DAIICT Garden" },
            { src: "https://www.daiict.ac.in/sites/default/files/2021-04/Campus%2019.JPG", alt: "DAIICT Grounds" },
            { src: "https://www.daiict.ac.in/sites/default/files/2021-04/Campus%2027_2.JPG", alt: "DAIICT Lawn" },
          ].map(({ src, alt }) => (
            <div class="overflow-hidden rounded-2xl group relative">
              <img
                src={src}
                alt={alt}
                class="w-full h-36 md:h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl"></div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- Venue Details + Features -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden flex flex-col lg:flex-row">

        <!-- Left: Details -->
        <div class="lg:w-1/2 p-8 md:p-10 flex flex-col justify-center">
          <h2 class="text-3xl font-black text-green-600 mb-7">Venue Details</h2>

          <div class="flex items-start gap-4 mb-6">
            <div class="w-10 h-10 rounded-xl bg-green-600 text-white flex items-center justify-center shrink-0 mt-0.5">
              <LocationIcon class="w-5 h-5" />
            </div>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">Location</h3>
              <a href={VENUE.googleMapsLink} target="_blank" rel="noreferrer noopener" class="text-green-600 font-semibold hover:underline transition">
                {VENUE.name}
              </a>
              <p class="text-gray-500 text-sm mt-0.5">{VENUE.address}</p>
            </div>
          </div>

          <div class="flex items-start gap-4 mb-6">
            <div class="w-10 h-10 rounded-xl bg-green-600 text-white flex items-center justify-center shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 9h10m-7 4h4m-5 5h6a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">Date &amp; Time</h3>
              <p class="text-gray-700 font-semibold">{VENUE.date} · 9:00 AM – 6:00 PM</p>
              <p class="text-gray-500 text-sm">{VENUE.format}</p>
            </div>
          </div>

          <div class="flex items-start gap-4 mb-6">
            <div class="w-10 h-10 rounded-xl bg-green-600 text-white flex items-center justify-center shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">Capacity</h3>
              <p class="text-gray-700 font-semibold">{VENUE.capacity}</p>
              <p class="text-gray-500 text-sm">Wheelchair accessible · Parking available</p>
            </div>
          </div>

          <a
            href={VENUE.googleMapsLink}
            target="_blank"
            rel="noreferrer noopener"
            class="inline-flex items-center gap-2 font-bold text-sm text-white bg-green-600 hover:bg-green-700 px-5 py-2.5 rounded-full transition-all hover:scale-105 self-start mt-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657 13.414 20.9a1.998 1.998 0 0 1-2.827 0l-4.244-4.243a8 8 0 1 1 11.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/></svg>
            Get Directions
          </a>
        </div>

        <!-- Divider -->
        <div class="hidden lg:block w-px bg-gray-100"></div>

        <!-- Right: Features -->
        <div class="lg:w-1/2 p-8 md:p-10 bg-gray-50 flex flex-col justify-center">
          <h2 class="text-3xl font-black text-green-600 mb-7">Venue Features</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {features.map(({ icon, label, desc }) => (
              <div class="flex items-center gap-3 bg-white border border-gray-100 hover:border-green-200 hover:shadow-sm rounded-xl p-4 transition-all duration-200 group">
                <span class="text-2xl">{icon}</span>
                <div>
                  <p class="font-semibold text-gray-900 text-sm group-hover:text-green-700 transition-colors">{label}</p>
                  <p class="text-gray-400 text-xs">{desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Transport & Connectivity -->
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10">
        <div>
          <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-1">Getting <span class="gradient-text">There</span></h2>
          <p class="text-gray-500">{SITE.city} is well-connected by air, rail, road &amp; metro</p>
        </div>
        <a
          href={VENUE.googleMapsLink}
          target="_blank"
          rel="noreferrer noopener"
          class="inline-flex items-center gap-2 text-sm font-bold text-white bg-gray-900 hover:bg-gray-800 px-5 py-2.5 rounded-full transition-all hover:scale-105 self-start sm:self-auto"
        >
          Open in Maps
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {transport.map(({ emoji, label, sub, dist }) => (
          <div class="flex items-center gap-4 p-5 rounded-2xl border border-gray-100 bg-white hover:border-green-200 hover:shadow-md transition-all duration-200">
            <span class="w-11 h-11 bg-green-500 rounded-xl flex items-center justify-center text-xl shrink-0">{emoji}</span>
            <div>
              <p class="font-semibold text-gray-900">{label}</p>
              <p class="text-gray-500 text-xs mt-0.5">{sub}</p>
              <span class="inline-block mt-1 px-2 py-0.5 text-xs bg-green-100 text-green-700 rounded-full font-medium">{dist}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="py-4 pb-16 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="rounded-2xl border border-gray-100 overflow-hidden shadow-md h-[420px]">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3667.4973993967537!2d72.62634057516976!3d23.188536979057695!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x395c2a3c9618d2c5%3A0xc54de484f986b1fa!2sDhirubhai%20Ambani%20University!5e0!3m2!1sen!2sin!4v1773815481392!5m2!1sen!2sin"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- OSD 2025 Reference CTA -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="bg-gradient-to-r from-green-50 to-emerald-50 border border-green-100 rounded-3xl p-8 md:p-12 flex flex-col md:flex-row items-center gap-6">
        <div class="flex-1 text-center md:text-left">
          <span class="inline-block bg-green-100 text-green-700 text-xs font-bold px-3 py-1 rounded-full mb-3 tracking-widest uppercase">Previous Edition</span>
          <h3 class="text-2xl font-black text-gray-900 mb-2">OSD 2025 was at <span class="gradient-text">Silver Oak University</span></h3>
          <p class="text-gray-500 text-sm">Check out the 2025 venue details, photos, and everything that made it special.</p>
        </div>
        <a
          href="/2025/venue"
          class="inline-flex items-center gap-2 font-bold text-white bg-gray-900 hover:bg-gray-800 px-8 py-3 rounded-full transition-all hover:scale-105 shrink-0"
        >
          View 2025 Venue →
        </a>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 px-4 bg-gray-50 text-center">
    <h3 class="text-xl font-bold text-gray-900 mb-2">Want to be a <span class="gradient-text">venue partner?</span></h3>
    <p class="text-gray-500 mb-2">Reach out to us at</p>
    <a href="mailto:opensourceweekend@gmail.com" class="text-green-600 hover:underline font-semibold">opensourceweekend@gmail.com</a>
  </section>
</Layout>
