---
// ── FAQ Data ─────────────────────────────────────────────────────────
const CHECKMARK = `<svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>`;
const faqCategories = [
  {
    label: "About the Event",
    items: [
      {
        q: "What is Open Source Day?",
        a: `<p>Open Source Day is a community driven, hands-on conference dedicated to the power of open collaboration. We believe that the most impactful technology isn't built in isolation, but through collective contribution.</p>
           <p class="mt-2">Open Source Day is the flagship annual conference by <strong class="text-gray-700">Open Source Weekend</strong> — a high-energy gathering designed to promote software freedom and bridge the gap between open-source communities and the tech industry.</p>`
      },
      {
        q: "What makes Open Source Day 2026 different from other tech meetups?",
        a: `<p>Open Source Day is defined by a shift from passive observation to active creation. This event is designed as a collaborative workspace where the goal is to <strong class="text-gray-700">build, iterate, and contribute</strong> — not just listen.</p>
           <ul class="mt-3 space-y-2">
             ${[
               "Unlike standard meetups, OSD 2026 is a massive, inclusive Open Ecosystem built on a decade of impact.",
               "We bring together everyone from students and academics to government organizations and business leaders.",
               "Our focus is on providing real resources and mentorship for aspiring contributors.",
               "With a network of 80+ partner communities and 200+ active volunteers, we are Gujarat's first and largest open-source community.",
             ].map(t => `<li class="flex items-start gap-2">${CHECKMARK}<span>${t}</span></li>`).join('')}
           </ul>`
      },
      {
        q: "I'm a complete beginner — is there a benefit for me?",
        a: `<p>Absolutely. Open Source Day is designed with beginners in mind. Fresh perspectives and beginner energy are vital for a thriving open-source community.</p>`
      }
    ]
  },
  {
    label: "Why Attend",
    items: [
      {
        q: "What are the key benefits of attending?",
        a: `<p>Attend OSD to build in public, master new stacks, and network with high-impact mentors. You'll also get:</p>
           <ul class="mt-3 space-y-2">
             ${[
               "Hands-on experience with AI, Cloud, and DevOps.",
               "A chance to turn GitHub contributions into a verifiable portfolio.",
               "Direct access to open-source maintainers and recruiters.",
             ].map(t => `<li class="flex items-start gap-2">${CHECKMARK}<span>${t}</span></li>`).join('')}
           </ul>`
      },
      {
        q: "Will food and refreshments be provided?",
        a: `<p>Yes! Your ticket includes <strong class="text-gray-700">breakfast and lunch</strong> throughout the day.</p>`
      },
      {
        q: "Do I need to bring my own laptop?",
        a: `<p>Yes, bringing your own laptop is highly recommended for our hands-on workshops.</p>`
      },
      {
        q: "I want to contribute to a specific project. How do I start?",
        a: `<p>We love that enthusiasm! Reach out to us via our social media or email us directly at <a href="mailto:opensourceweekend@gmail.com" class="text-green-600 hover:underline font-semibold">opensourceweekend@gmail.com</a>.</p>`
      }
    ]
  },
  {
    label: "Registration & Tickets",
    items: [
      {
        q: "How do I use my company's membership discount?",
        a: `<ol class="space-y-2 list-none">
             ${[
               "Visit osd.opensourceweekend.org/tickets/.",
               "Select your ticket.",
               "Enter the discount code provided by your organization during checkout.",
             ].map((text, i) => `<li class="flex items-start gap-3"><span class="w-5 h-5 rounded-full bg-green-500 text-white text-[0.6rem] font-black flex items-center justify-center shrink-0 mt-0.5">${i+1}</span><span>${text}</span></li>`).join('')}
           </ol>`
      },
      {
        q: "Will I receive an email confirmation after registering?",
        a: `<p>Yes, absolutely. Once your registration is processed, you will receive an email confirmation containing your <strong class="text-gray-700">unique QR code</strong>.</p>`
      },
      {
        q: "Can I transfer my ticket?",
        a: `<div class="inline-flex items-center gap-1.5 bg-red-50 border border-red-100 text-red-700 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide mb-3">Non-Transferable & Non-Refundable</div>
           <p>Tickets for OSD 2026 are non-transferable and non-refundable.</p>`
      },
      {
        q: "How do I register?",
        a: `<p class="mb-3">Visit our ticket page, select your tier, complete payment, and save your QR code for entry!</p>`
      }
    ]
  },
  {
    label: "For Leaders & Executives",
    items: [
      {
        q: "What perks do executives get?",
        a: `<ul class="space-y-3">
             ${[
               { title: "Complimentary Pass", desc: "Full access to keynotes and networking sessions." },
               { title: "Access to Top Talent", desc: "Direct access to skilled developers and contributors." },
               { title: "Strategic Networking", desc: "Connect with founders and technology leaders." },
               { title: "Tech Insights", desc: "Gain perspective on the latest AI, Cloud, and DevOps trends." },
             ].map(({ title, desc }) => `
               <li class="flex items-start gap-3 p-3 bg-gray-50 rounded-xl">
                 ${CHECKMARK}
                 <div>
                   <div class="font-bold text-gray-900 text-xs uppercase tracking-wide mb-0.5">${title}</div>
                   <div class="text-gray-500">${desc}</div>
                 </div>
               </li>
             `).join('')}
           </ul>`
      }
    ]
  }
];
---


<!-- FAQ Accordion -->
  <section class="py-20 px-4 bg-white" id="faq">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-green-50 text-green-700 text-xs font-bold border border-green-200 mb-4 uppercase tracking-widest">FAQ</div>
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Frequently Asked <span class="gradient-text">Questions</span></h2>
        <p class="text-gray-500">Everything you need to know about Open Source Day 2026</p>
      </div>

      {faqCategories.map((category) => (
        <div class="mb-10">
          <!-- Category header -->
          <div class="flex items-center gap-3 mb-5">
            <span class="text-xs font-black uppercase tracking-widest text-green-700 bg-green-50 border border-green-200 px-3 py-1 rounded-full whitespace-nowrap">
              {category.label}
            </span>
            <div class="h-px flex-1 bg-gradient-to-r from-green-100 to-transparent"></div>
          </div>

          <!-- FAQ items -->
          <div class="space-y-3">
            {category.items.map((faq) => (
              <details class="faq-item group border border-gray-100 rounded-2xl overflow-hidden bg-white hover:border-green-200 transition-colors">
                <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-bold text-gray-900 text-sm sm:text-base">
                  <span>{faq.q}</span>
                  <span class="faq-chevron w-7 h-7 rounded-full bg-gray-100 group-open:bg-green-500 flex items-center justify-center shrink-0 transition-colors">
                    <svg class="w-3.5 h-3.5 text-gray-500 group-open:text-white group-open:rotate-180 transition-all duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </span>
                </summary>
                <div class="px-6 pb-6 pt-4 text-gray-500 text-sm leading-relaxed space-y-2 border-t border-gray-50" set:html={faq.a} />
              </details>
            ))}
          </div>
        </div>
      ))}

    </div>
  </section>  <style>
    details.faq-item summary::-webkit-details-marker { display: none; }
    details.faq-item[open] summary { border-bottom: 1px solid #f3f4f6; }
    details.faq-item .faq-chevron svg { transition: transform 0.2s ease; }
  </style>
