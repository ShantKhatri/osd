---
// Simple optimized image wrapper. Replace the internal <img> with Astro's <Image> integration
// when you enable `@astrojs/image` or a similar integration.
export interface Props {
  src: string;
  alt?: string;
  class?: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
}
const { src, alt = '', class: cls = '', width, height, loading = 'lazy' } = Astro.props;
---
<img src={src} alt={alt} class={cls} width={width} height={height} loading={loading} />
